{
  "name": "value-investing-course",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "npm run import:live && npm run import:portfolio && npm run import:dcf-learning && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "import:live": "python3 scripts/import_live_companions.py",
    "import:portfolio": "python3 scripts/import_portfolio_candidates.py",
    "import:dcf-learning": "python3 scripts/import_dcf_learning.py",
    "refresh:macro": "python3 scripts/import_macro_snapshot.py",
    "verify:live": "python3 scripts/verify_live_companions.py",
    "verify:macro": "python3 scripts/verify_macro_snapshot.py",
    "test:macro": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "verify:portfolio": "python3 scripts/verify_portfolio_candidates.py",
    "verify:dcf-learning": "python3 scripts/verify_dcf_learning.py",
    "test:portfolio": "python3 -m unittest discover -s tests -p 'test_portfolio_*.py'",
    "check": "npm run import:live && npm run import:portfolio && npm run import:dcf-learning && ASTRO_TELEMETRY_DISABLED=1 astro check"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.35.0",
    "astro": "^5.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "typescript": "^5.7.0"
  }
}
